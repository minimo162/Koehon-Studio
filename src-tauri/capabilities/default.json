{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions",
  "windows": ["main"],
  "permissions": [
    "dialog:default",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-create",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**/*", "$APPDATA/**/*", "$DOCUMENT/**/*"]
    },
    "opener:default",
    "opener:allow-open-path",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "../native-tts/sidecars/koehon-tts-sidecar",
          "sidecar": true,
          "args": [
            "--host",
            { "validator": "^[0-9.:]+$" },
            "--model-dir",
            { "validator": "^[^\\n]*$" },
            "--ort-dylib",
            { "validator": "^[^\\n]*$" },
            "--cpu-threads",
            { "validator": "^[0-9]+$" }
          ]
        }
      ]
    },
    "shell:allow-kill"
  ]
}
