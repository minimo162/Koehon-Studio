{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koehon Studio",
  "version": "0.1.0",
  "identifier": "studio.koehon.app",
  "build": {
    "beforeDevCommand": "pnpm build:sidecar && pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Koehon Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../native-tts/sidecars/koehon-tts-sidecar"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
